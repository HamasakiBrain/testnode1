generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkType {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  unit      String
  entries   LogEntry[]
}

model LogEntry {
  id          Int      @id @default(autoincrement())
  date        DateTime
  workTypeId  Int
  workType    WorkType @relation(fields: [workTypeId], references: [id])
  volume      Float
  workerName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
